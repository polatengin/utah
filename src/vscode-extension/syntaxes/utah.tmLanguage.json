{
    "scopeName": "source.utah",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#multiline-strings"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#template-strings"
        },
        {
            "include": "#namespace-calls"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#variables"
        }
    ],
    "repository": {
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.utah",
                    "match": "\\b(if|else|for|in|while|switch|case|default|break|continue|return|try|catch|defer|import|parallel)\\b"
                },
                {
                    "name": "keyword.declaration.utah",
                    "match": "\\b(const|let|function|record|interface)\\b"
                },
                {
                    "name": "keyword.other.utah",
                    "match": "\\b(exit)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.utah",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.numeric.utah",
                    "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
                }
            ]
        },
        "namespace-calls": {
            "patterns": [
                {
                    "name": "meta.namespace-call.utah",
                    "match": "\\b(console|fs|os|process|git|utility|timer|string|math|script|web|json|yaml|validate|ssh|system|template|scheduler|args|array|env)\\s*\\.\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                    "captures": {
                        "1": {
                            "name": "support.class.utah"
                        },
                        "2": {
                            "name": "support.function.utah"
                        }
                    }
                }
            ]
        },
        "multiline-strings": {
            "name": "string.quoted.triple.utah",
            "begin": "\"\"\"",
            "end": "\"\"\"",
            "patterns": [
                {
                    "include": "#interpolation"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.utah",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "include": "#interpolation"
                },
                {
                    "name": "constant.character.escape.utah",
                    "match": "\\\\."
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.utah",
                    "begin": "/\\*",
                    "end": "\\*/"
                },
                {
                    "name": "comment.line.double-slash.utah",
                    "begin": "//",
                    "end": "$"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.utah",
                    "match": "\\b(string|boolean|number|void|string\\[\\]|number\\[\\]|boolean\\[\\])\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.utah",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.utah",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b"
                }
            ]
        },
        "template-strings": {
            "name": "string.template.utah",
            "begin": "`",
            "end": "`",
            "patterns": [
                {
                    "include": "#interpolation"
                },
                {
                    "name": "constant.character.escape.utah",
                    "match": "\\\\."
                }
            ]
        },
        "interpolation": {
            "name": "meta.interpolation.utah",
            "begin": "\\${",
            "end": "}",
            "patterns": [
                {
                    "include": "#functions"
                },
                {
                    "include": "#variables"
                }
            ]
        }
    }
}
